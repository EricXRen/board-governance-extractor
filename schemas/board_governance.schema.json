{
  "$defs": {
    "AttendanceDetails": {
      "additionalProperties": false,
      "description": "Board and committee meeting attendance.",
      "properties": {
        "board_meetings_attended": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Board Meetings Attended"
        },
        "board_meetings_scheduled": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Board Meetings Scheduled"
        },
        "board_attendance_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Board Attendance Pct"
        },
        "committee_attendance": {
          "default": [],
          "items": {
            "$ref": "#/$defs/CommitteeAttendance"
          },
          "title": "Committee Attendance",
          "type": "array"
        },
        "attendance_notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attendance Notes"
        }
      },
      "title": "AttendanceDetails",
      "type": "object"
    },
    "BiographicalDetails": {
      "additionalProperties": false,
      "description": "Biographical and professional background of a director.",
      "properties": {
        "full_name": {
          "title": "Full Name",
          "type": "string"
        },
        "post_nominals": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Post Nominals"
        },
        "age": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Age"
        },
        "age_band": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Age Band"
        },
        "gender": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gender"
        },
        "affiliation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Affiliation"
        },
        "career_summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Career Summary"
        }
      },
      "required": [
        "full_name"
      ],
      "title": "BiographicalDetails",
      "type": "object"
    },
    "BoardRoleDetails": {
      "additionalProperties": false,
      "description": "Board role, independence, tenure, and committee information.",
      "properties": {
        "designation": {
          "enum": [
            "Executive Director",
            "Non-Executive Director",
            "Chair"
          ],
          "title": "Designation",
          "type": "string"
        },
        "board_role": {
          "title": "Board Role",
          "type": "string"
        },
        "independence_status": {
          "enum": [
            "Independent",
            "Not Independent",
            "Chair (independent on appointment)",
            "N/A (Executive)"
          ],
          "title": "Independence Status",
          "type": "string"
        },
        "year_joined_board": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Year Joined Board"
        },
        "date_joined_board": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Date Joined Board"
        },
        "tenure_years": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tenure Years"
        },
        "term_end_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Term End Year"
        },
        "year_end_status": {
          "title": "Year End Status",
          "type": "string"
        },
        "committee_memberships": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Committee Memberships",
          "type": "array"
        },
        "committee_chair_of": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Committee Chair Of",
          "type": "array"
        },
        "other_positions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Other Positions",
          "type": "array"
        },
        "num_holding_shares": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Num Holding Shares"
        },
        "pct_holding_shares": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pct Holding Shares"
        }
      },
      "required": [
        "designation",
        "board_role",
        "independence_status",
        "year_end_status"
      ],
      "title": "BoardRoleDetails",
      "type": "object"
    },
    "BoardSummary": {
      "additionalProperties": false,
      "description": "Aggregate governance statistics for the full board.\n\nFields are populated from two sources (priority order):\n1. Explicitly stated values extracted from the filing text.\n2. Values computed from the extracted Director list (where derivable).\n\nOnly ``voting_standard`` must come exclusively from the filing text;\nall other fields have a computation fallback.",
      "properties": {
        "ceo_chair_separated": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ceo Chair Separated"
        },
        "voting_standard": {
          "anyOf": [
            {
              "enum": [
                "Majority",
                "Plurality"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Voting Standard"
        },
        "board_evaluation": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Board Evaluation"
        },
        "board_size": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Board Size"
        },
        "num_executive_directors": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Num Executive Directors"
        },
        "num_non_executive_directors": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Num Non Executive Directors"
        },
        "num_independent_directors": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Num Independent Directors"
        },
        "pct_women": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pct Women"
        },
        "pct_independent": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pct Independent"
        },
        "avg_director_age": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Avg Director Age"
        },
        "avg_tenure_years": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Avg Tenure Years"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        }
      },
      "title": "BoardSummary",
      "type": "object"
    },
    "CommitteeAttendance": {
      "additionalProperties": false,
      "description": "Attendance record for a single committee.",
      "properties": {
        "committee_name": {
          "title": "Committee Name",
          "type": "string"
        },
        "meetings_attended": {
          "title": "Meetings Attended",
          "type": "integer"
        },
        "meetings_scheduled": {
          "title": "Meetings Scheduled",
          "type": "integer"
        },
        "attendance_pct": {
          "title": "Attendance Pct",
          "type": "number"
        },
        "is_chair": {
          "default": false,
          "title": "Is Chair",
          "type": "boolean"
        }
      },
      "required": [
        "committee_name",
        "meetings_attended",
        "meetings_scheduled",
        "attendance_pct"
      ],
      "title": "CommitteeAttendance",
      "type": "object"
    },
    "CompanyMetadata": {
      "additionalProperties": false,
      "description": "Metadata about the filing and extraction run.",
      "properties": {
        "company_name": {
          "title": "Company Name",
          "type": "string"
        },
        "company_ticker": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Company Ticker"
        },
        "filing_type": {
          "title": "Filing Type",
          "type": "string"
        },
        "fiscal_year_end": {
          "title": "Fiscal Year End",
          "type": "string"
        },
        "report_date": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Report Date"
        },
        "source_pdf_path": {
          "title": "Source Pdf Path",
          "type": "string"
        },
        "extraction_timestamp": {
          "title": "Extraction Timestamp",
          "type": "string"
        },
        "llm_provider": {
          "title": "Llm Provider",
          "type": "string"
        },
        "llm_model": {
          "title": "Llm Model",
          "type": "string"
        }
      },
      "required": [
        "company_name",
        "filing_type",
        "fiscal_year_end",
        "source_pdf_path",
        "extraction_timestamp",
        "llm_provider",
        "llm_model"
      ],
      "title": "CompanyMetadata",
      "type": "object"
    },
    "CurrentBoard": {
      "additionalProperties": false,
      "description": "Current board composition: aggregate summary plus individual director details.",
      "properties": {
        "summary": {
          "$ref": "#/$defs/BoardSummary"
        },
        "directors": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Director"
          },
          "title": "Directors",
          "type": "array"
        }
      },
      "title": "CurrentBoard",
      "type": "object"
    },
    "Director": {
      "additionalProperties": false,
      "description": "Complete director record combining all sub-models.",
      "properties": {
        "biographical": {
          "$ref": "#/$defs/BiographicalDetails"
        },
        "board_role": {
          "$ref": "#/$defs/BoardRoleDetails"
        },
        "attendance": {
          "$ref": "#/$defs/AttendanceDetails"
        }
      },
      "required": [
        "biographical",
        "board_role",
        "attendance"
      ],
      "title": "Director",
      "type": "object"
    },
    "DirectorElection": {
      "additionalProperties": false,
      "description": "Director election section: summary plus full candidate details.",
      "properties": {
        "summary": {
          "$ref": "#/$defs/DirectorElectionSummary"
        },
        "candidates": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Director"
          },
          "title": "Candidates",
          "type": "array"
        }
      },
      "title": "DirectorElection",
      "type": "object"
    },
    "DirectorElectionSummary": {
      "additionalProperties": false,
      "description": "Aggregate summary of the director election proposed in the filing.",
      "properties": {
        "num_directors_to_elect": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Num Directors To Elect"
        },
        "incumbent_nominees": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Incumbent Nominees",
          "type": "array"
        },
        "new_nominees": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "New Nominees",
          "type": "array"
        },
        "candidates_disclosed": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidates Disclosed"
        }
      },
      "title": "DirectorElectionSummary",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Complete extraction output: company metadata, current board, and director election.",
  "properties": {
    "company": {
      "$ref": "#/$defs/CompanyMetadata"
    },
    "current_board": {
      "$ref": "#/$defs/CurrentBoard"
    },
    "director_election": {
      "anyOf": [
        {
          "$ref": "#/$defs/DirectorElection"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "company"
  ],
  "title": "BoardGovernanceDocument",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0"
}